    private void PreviewVersion(PlanningNoteVersion ver) => _previewVersion = _previewVersion?.Id == ver.Id ? null : ver;

    private async Task RestoreVersion(PlanningNoteVersion ver)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Versie {ver.VersionNumber} herstellen?");
        if (!confirmed) return;
        var snapshot = DeserializeSnapshot(ver.SnapshotJson);
        if (snapshot is null) return;
        Note.Title = snapshot.Title;
        _editBlocks = snapshot.Blocks.Select(b => new PlanningBlock
        {
            Id = GetTempBlockId(), NoteId = Note.Id,
            Type = Enum.TryParse<BlockType>(b.Type, out var bt) ? bt : BlockType.Text,
            Content = b.Content, IsChecked = b.IsChecked, SortOrder = b.SortOrder, IndentLevel = b.IndentLevel
        }).ToList();
        _hasUnsavedChanges = true;
        await LogAudit("restored", $"Hersteld naar versie {ver.VersionNumber}");
        await SaveNote();
        StateHasChanged();
    }

    // ===================== HELPERS =====================
    private void NormalizeBlockOrder()
    {
        var ordered = _editBlocks.OrderBy(b => b.SortOrder).ToList();
        for (int i = 0; i < ordered.Count; i++) ordered[i].SortOrder = i + 1;
    }

    private bool IsBlockHiddenByCollapse(PlanningBlock block)
    {
        var ordered = _editBlocks.OrderBy(b => b.SortOrder).ToList();
        var idx = ordered.IndexOf(block);
        if (idx <= 0) return false;
        for (int i = idx - 1; i >= 0; i--)
        {
            var prev = ordered[i];
            if (prev.IndentLevel < block.IndentLevel) { if (prev.IsCollapsed) return true; if (prev.IndentLevel == 0) break; }
            else if (prev.IndentLevel < block.IndentLevel - 1) break;
        }
        return false;
    }

    private bool HasVisibleChildren(PlanningBlock block)
    {
        var ordered = _editBlocks.OrderBy(b => b.SortOrder).ToList();
        var idx = ordered.IndexOf(block);
        if (idx < 0 || idx >= ordered.Count - 1) return false;
        return ordered[idx + 1].IndentLevel > block.IndentLevel;
    }

    private string CreateSnapshot(string title, List<PlanningBlock> blocks)
    {
        var snapshot = new NoteSnapshot
        {
            Title = title,
            Blocks = blocks.Select(b => new BlockSnapshot
            {
                Type = b.Type.ToString(), Content = b.Content, IsChecked = b.IsChecked,
                SortOrder = b.SortOrder, IndentLevel = b.IndentLevel, AssignedToId = b.AssignedToId,
                ItemStatus = b.ItemStatus?.ToString(), Priority = b.Priority?.ToString(), Deadline = b.Deadline
            }).ToList()
        };
        return JsonSerializer.Serialize(snapshot);
    }

    private static NoteSnapshot? DeserializeSnapshot(string json)
    {
        try { return JsonSerializer.Deserialize<NoteSnapshot>(json); }
        catch { return null; }
    }

    private async Task LogAudit(string action, string details)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.PlanningAuditLogs.Add(new PlanningAuditLog { NoteId = Note.Id, Action = action, Details = details, UserId = CurrentUser.Id });
            await db.SaveChangesAsync();
        }
        catch { }
    }

    private sealed record AttachmentMeta(string FileName, string ContentType, long FileSize);

    private class NoteSnapshot
    {
        public string Title { get; set; } = "";
        public List<BlockSnapshot> Blocks { get; set; } = [];
    }

    private class BlockSnapshot
    {
        public string Type { get; set; } = "Text";
        public string Content { get; set; } = "";
        public bool IsChecked { get; set; }
        public int SortOrder { get; set; }
        public int IndentLevel { get; set; }
        public int? AssignedToId { get; set; }
        public string? ItemStatus { get; set; }
        public string? Priority { get; set; }
        public DateTime? Deadline { get; set; }
    }
}

