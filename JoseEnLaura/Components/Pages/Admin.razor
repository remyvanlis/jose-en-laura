                        {
                            var capturedSession = session;
                            var sessionIndex = orderedSessions.IndexOf(session) + 1;
                            <div class="photo-session-card"
                                 draggable="true"
                                 @ondragstart="() => OnPhotoDragStart(capturedSession)"
                                 @ondragover:preventDefault
                                 @ondrop="() => OnPhotoDrop(capturedSession)"
