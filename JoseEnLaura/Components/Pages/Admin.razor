    private async Task MoveScheduleItem(Data.Models.ScheduleItem item, int direction)
    {
        var siblings = _scheduleItems
            .Where(s => s.ParentId == item.ParentId)
            .OrderBy(s => s.SortOrder)
            .ToList();

        var idx = siblings.FindIndex(s => s.Id == item.Id);
        var targetIdx = idx + direction;
        if (targetIdx < 0 || targetIdx >= siblings.Count) return;

        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            
            // First, normalize all sibling sort orders to ensure they are unique and sequential
            var dbSiblings = await db.ScheduleItems
                .Where(s => s.ParentId == item.ParentId)
                .OrderBy(s => s.SortOrder)
                .ThenBy(s => s.Id)
                .ToListAsync();
            
            for (int i = 0; i < dbSiblings.Count; i++)
            {
                dbSiblings[i].SortOrder = i + 1;
            }
            await db.SaveChangesAsync();
            
            // Now find the two items and swap them
            var orderedSiblings = dbSiblings.OrderBy(s => s.SortOrder).ToList();
            var currentIdx = orderedSiblings.FindIndex(s => s.Id == item.Id);
            var swapIdx = currentIdx + direction;
            if (swapIdx >= 0 && swapIdx < orderedSiblings.Count)
            {
                var a = orderedSiblings[currentIdx];
                var b = orderedSiblings[swapIdx];
                (a.SortOrder, b.SortOrder) = (b.SortOrder, a.SortOrder);
                await db.SaveChangesAsync();
            }
            
            await LoadScheduleItems();
        }
        finally
        {
            _isBusy = false;
        }
    }

