                    }
                </div>
            }

            <!-- TAB: Image Management -->
            @if (_activeTab == "images")
            {
                <div class="admin-card">
                    <h3>Afbeeldingen beheren</h3>
                    <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
                        Upload afbeeldingen voor de verschillende plekken op de website. Toegestane formaten: JPG, JPEG, PNG. Max 5 MB.
                    </p>

                    @foreach (var slot in _imageSlots)
                    {
                        var capturedSlot = slot;
                        var existingImage = _siteImages.FirstOrDefault(i => i.Slot == slot.Key);
                        <div class="image-slot-card" style="border: 2px solid var(--color-cream-dark); border-radius: 12px; padding: 1.2rem; margin-bottom: 1rem; background: var(--color-cream);">
                            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.8rem;">
                                <div>
                                    <strong style="color: var(--color-terracotta-dark); font-size: 1.05rem;">@slot.Value</strong>
                                    <small style="display: block; color: var(--color-text-light); font-family: monospace;">@slot.Key</small>
                                </div>
                                @if (existingImage is not null)
                                {
                                    <span class="badge badge-confirmed">&#10003; @existingImage.FileName</span>
                                }
                                else
                                {
                                    <span class="badge badge-pending">Nog geen afbeelding</span>
                                }
                            </div>
                            @if (existingImage is not null)
                            {
                                <div style="margin-bottom: 0.8rem; text-align: center;">
                                    <img src="/api/site-image/@slot.Key?v=@existingImage.Id" alt="@slot.Value" style="max-width: 100%; max-height: 200px; border-radius: 8px; object-fit: cover; border: 1px solid var(--color-cream-dark);" />
                                </div>
                            }
                            <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
                                <InputFile OnChange="(e) => OnImageSelected(capturedSlot.Key, capturedSlot.Value, e)" accept=".jpg,.jpeg,.png" style="font-size: 0.9rem;" />
                                @if (existingImage is not null)
                                {
                                    <button class="btn-icon btn-delete" @onclick="() => DeleteImage(existingImage.Id)" title="Verwijderen">&#128465; Verwijderen</button>
                                }
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_imageMessage))
                    {
                        <div class="admin-success">@_imageMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(_imageError))
                    {
                        <div class="admin-error">@_imageError</div>
                    }
                </div>
            }

            <!-- TAB: Photo Sessions -->
            @if (_activeTab == "photos")
            {
                <div class="admin-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem;">
                        <h3 style="margin: 0;">📸 Foto Sessies (@_photoSessions.Count)</h3>
                        <label @onclick="() => { _photoOnlyAttending = !_photoOnlyAttending; }" @onclick:preventDefault
                               style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; font-size: 0.9rem; font-family: var(--font-sans); padding: 0.4rem 0.8rem; border-radius: 10px; border: 2px solid @(_photoOnlyAttending ? "var(--color-sage)" : "var(--color-cream-dark)"); background: @(_photoOnlyAttending ? "rgba(138,154,123,0.1)" : "transparent"); transition: all 0.2s; user-select: none;">
                            <span style="display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 6px; border: 2px solid @(_photoOnlyAttending ? "var(--color-sage)" : "var(--color-cream-dark)"); background: @(_photoOnlyAttending ? "var(--color-sage)" : "white"); color: white; font-size: 0.8rem; transition: all 0.2s;">
                                @if (_photoOnlyAttending) { <text>&#10003;</text> }
