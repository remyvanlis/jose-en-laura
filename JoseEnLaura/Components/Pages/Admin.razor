    private void OnRsvpGuestSelected()
    {
        _rsvpSaveMessage = "";
        _rsvpSaveError = "";
        var guest = _guests.FirstOrDefault(g => g.Id == _rsvpSelectedGuestId);
        if (guest?.Attendance is not null)
        {
            _rsvpCeremony = guest.Attendance.AttendingCeremony;
            _rsvpDinner = guest.Attendance.AttendingDinner;
            _rsvpEvening = guest.Attendance.AttendingEvening;
            _rsvpDietary = guest.Attendance.DietaryNotes ?? "";
            _rsvpMessage = guest.Attendance.Message ?? "";
        }
        else
        {
            // Pre-fill defaults based on invitation type
            if (guest is not null)
            {
                _rsvpCeremony = guest.InvitedFor is InvitedForType.Ceremony or InvitedForType.CeremonyAndEvening or InvitedForType.DayGuest;
                _rsvpDinner = guest.InvitedFor is InvitedForType.DayGuest;
                _rsvpEvening = guest.InvitedFor is InvitedForType.Evening or InvitedForType.CeremonyAndEvening or InvitedForType.DayGuest;
            }
            else
            {
                _rsvpCeremony = false;
                _rsvpDinner = false;
                _rsvpEvening = false;
            }
            _rsvpDietary = "";
            _rsvpMessage = "";
        }
    }

    private async Task SaveAdminRsvp()
    {
        _rsvpSaveMessage = "";
        _rsvpSaveError = "";

        if (_rsvpSelectedGuestId <= 0)
        {
            _rsvpSaveError = "Selecteer eerst een gast.";
            return;
        }

        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var guest = await db.Guests
                .Include(g => g.Attendance)
                .FirstOrDefaultAsync(g => g.Id == _rsvpSelectedGuestId);

            if (guest is null)
            {
                _rsvpSaveError = "Gast niet gevonden.";
                return;
            }

            if (guest.Attendance is null)
            {
                db.Attendances.Add(new Attendance
                {
                    GuestId = guest.Id,
                    AttendingCeremony = _rsvpCeremony,
                    AttendingDinner = _rsvpDinner,
                    AttendingEvening = _rsvpEvening,
                    DietaryNotes = string.IsNullOrWhiteSpace(_rsvpDietary) ? null : _rsvpDietary.Trim(),
                    Message = string.IsNullOrWhiteSpace(_rsvpMessage) ? null : _rsvpMessage.Trim(),
                    SubmittedAt = DateTime.UtcNow
                });
            }
            else
            {
                guest.Attendance.AttendingCeremony = _rsvpCeremony;
                guest.Attendance.AttendingDinner = _rsvpDinner;
                guest.Attendance.AttendingEvening = _rsvpEvening;
                guest.Attendance.DietaryNotes = string.IsNullOrWhiteSpace(_rsvpDietary) ? null : _rsvpDietary.Trim();
                guest.Attendance.Message = string.IsNullOrWhiteSpace(_rsvpMessage) ? null : _rsvpMessage.Trim();
                guest.Attendance.UpdatedAt = DateTime.UtcNow;
            }

            await db.SaveChangesAsync();
            _rsvpSaveMessage = $"RSVP voor {guest.FullName} opgeslagen!";
            await LoadGuests();

            // Fire webhook (fire-and-forget, don't block UI)
            _ = SendRsvpWebhook(guest.FullName, _rsvpCeremony, _rsvpDinner, _rsvpEvening);
        }
        finally
        {
            _isBusy = false;
        }
    }

