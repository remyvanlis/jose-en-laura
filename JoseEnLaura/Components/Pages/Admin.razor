    private async Task DeletePhotoSession(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Weet je zeker dat je deze foto sessie wilt verwijderen?");
        if (!confirmed) return;

        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var session = await db.PhotoSessions.FindAsync(id);
            if (session is not null)
            {
                db.PhotoSessions.Remove(session);
                await db.SaveChangesAsync();
            }
            await LoadPhotoSessions();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void StartEditPhotoSession(PhotoSession session)
    {
        _editingPhotoSessionId = session.Id;
        _editPhotoSessionName = session.Name;
    }

    private void CancelPhotoSessionEdit()
    {
        _editingPhotoSessionId = null;
    }

    private async Task OnEditPhotoSessionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SavePhotoSessionEdit();
        else if (e.Key == "Escape") CancelPhotoSessionEdit();
    }

    private async Task SavePhotoSessionEdit()
    {
        if (_editingPhotoSessionId is null) return;

        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var session = await db.PhotoSessions.FindAsync(_editingPhotoSessionId.Value);
            if (session is not null)
            {
                session.Name = _editPhotoSessionName.Trim();
                await db.SaveChangesAsync();
            }
            _editingPhotoSessionId = null;
            await LoadPhotoSessions();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task AddGuestToSession(int sessionId, int guestId)
    {
        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var exists = await db.PhotoSessionGuests.AnyAsync(sg => sg.PhotoSessionId == sessionId && sg.GuestId == guestId);
            if (!exists)
            {
                db.PhotoSessionGuests.Add(new PhotoSessionGuest
                {
                    PhotoSessionId = sessionId,
                    GuestId = guestId
                });
                await db.SaveChangesAsync();
            }
            _photoGuestSearch = "";
            // Keep _photoSearchSessionId so the input stays active for the next guest
            await LoadPhotoSessions();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RemoveGuestFromSession(int sessionId, int guestId)
    {
        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var sg = await db.PhotoSessionGuests.FirstOrDefaultAsync(x => x.PhotoSessionId == sessionId && x.GuestId == guestId);
            if (sg is not null)
            {
                db.PhotoSessionGuests.Remove(sg);
                await db.SaveChangesAsync();
            }
            await LoadPhotoSessions();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void OnPhotoDragStart(PhotoSession session)
    {
        _dragPhotoSessionId = session.Id;
    }

    private async Task OnPhotoDrop(PhotoSession target)
    {
        if (_dragPhotoSessionId is null || _dragPhotoSessionId == target.Id)
        {
            _dragPhotoSessionId = null;
            return;
        }

        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var sessions = await db.PhotoSessions.OrderBy(s => s.SortOrder).ToListAsync();
            var draggedIdx = sessions.FindIndex(s => s.Id == _dragPhotoSessionId);
            var targetIdx = sessions.FindIndex(s => s.Id == target.Id);

            if (draggedIdx >= 0 && targetIdx >= 0)
            {
                var dragged = sessions[draggedIdx];
                sessions.RemoveAt(draggedIdx);
                sessions.Insert(targetIdx, dragged);

                for (int i = 0; i < sessions.Count; i++)
                {
                    sessions[i].SortOrder = i + 1;
                }
                await db.SaveChangesAsync();
            }

            _dragPhotoSessionId = null;
            await LoadPhotoSessions();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private List<Guest> GetFilteredPhotoGuests()
    {
        if (_photoOnlyAttending)
        {
            return _guests.Where(g => g.Attendance is not null &&
                (g.Attendance.AttendingCeremony || g.Attendance.AttendingDinner || g.Attendance.AttendingEvening)).ToList();
        }
        return _guests;
    }

    private void OnPhotoGuestSearchInput(ChangeEventArgs e)
    {
        _photoGuestSearch = e.Value?.ToString() ?? "";
    }

    private async Task OnPhotoGuestSearchKeyDown(KeyboardEventArgs e, PhotoSession session)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_photoGuestSearch)) return;

        var existingGuestIds = session.Guests.Select(g => g.GuestId).ToHashSet();
        var matches = GetFilteredPhotoGuests()
            .Where(g => !existingGuestIds.Contains(g.Id))
            .Where(g => g.FullName.Contains(_photoGuestSearch, StringComparison.OrdinalIgnoreCase))
            .Take(2).ToList();

        if (matches.Count == 1)
        {
            await AddGuestToSession(session.Id, matches[0].Id);
        }
    }

    private sealed record AdminSession(int UserId, DateTime ExpiresUtc);
}

