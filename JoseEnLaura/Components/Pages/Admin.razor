                                                <input type="text" class="form-input form-input-sm" style="border-left: 3px solid var(--color-sage-light);" @bind="_addSubDescEn" placeholder="English..." />
                                            </div>
                                            <button class="btn-icon btn-save" @onclick="SaveNewSubItem" title="Opslaan" style="height: 32px;">&#10003;</button>
                                            <button class="btn-icon btn-cancel" @onclick="CancelAddSubItem" title="Annuleren" style="height: 32px;">&#10007;</button>
