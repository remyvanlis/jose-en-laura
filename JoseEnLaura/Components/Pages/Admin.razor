        { "hero-bg", "Hero achtergrond (grote foto bovenaan)" },
        { "access-bg", "Toegangspagina achtergrond (inlogscherm)" },
        { "photo-strip-1", "Fotostrip — Foto 1 (links)" },
        { "photo-strip-2", "Fotostrip — Foto 2 (midden)" },
        { "photo-strip-3", "Fotostrip — Foto 3 (rechts)" },
        { "full-photo", "Grote foto sectie (quote achtergrond)" }
    };

    // Visitor Log
    private List<(DateOnly Date, int Count)> _visitorLogDays = [];

    // Photo Session Management
    private List<PhotoSession> _photoSessions = [];
    private string _newPhotoSessionName = "";
    private string _photoSessionMessage = "";
    private bool _photoOnlyAttending;
    private int? _dragPhotoSessionId;
    private int? _editingPhotoSessionId;
    private string _editPhotoSessionName = "";
    private int? _photoSearchSessionId;
    private string _photoGuestSearch = "";

    private bool _selectedUserNeedsSetup
    {
        get
        {
            var user = _adminUsers.FirstOrDefault(u => u.Name == _selectedUserName);
            return user is not null && string.IsNullOrEmpty(user.PasswordHash);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _adminUsers = await db.AdminUsers.ToListAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var result = await LocalStorage.GetAsync<AdminSession>(SessionKey);
            if (result is { Success: true, Value: not null })
            {
                var session = result.Value;
                if (session.ExpiresUtc > DateTime.UtcNow)
                {
                    await using var db = await DbFactory.CreateDbContextAsync();
                    var user = await db.AdminUsers.FindAsync(session.UserId);
                    if (user is not null)
                    {
                        _currentUser = user;
                        await LoadGuests();
                        await LoadFaqItems();
                    }
                }
                else
                {
                    await LocalStorage.DeleteAsync(SessionKey);
                }
            }
        }
        catch
        {
            // Storage not available or corrupted — ignore
        }

        _isLoading = false;
        StateHasChanged();
    }

    // ========================
    //   LOGIN
    // ========================
    private async Task HandleLogin()
    {
        _loginError = "";

        if (string.IsNullOrWhiteSpace(_selectedUserName))
        {
            _loginError = "Selecteer eerst je naam.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 4)
        {
            _loginError = "Wachtwoord moet minimaal 4 tekens zijn.";
            return;
        }

        _isBusy = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var user = await db.AdminUsers.FirstOrDefaultAsync(u => u.Name == _selectedUserName);
            if (user is null) return;

            if (string.IsNullOrEmpty(user.PasswordHash))
            {
                // First time — set password
                user.PasswordHash = BCrypt.Net.BCrypt.HashPassword(_password);
                await db.SaveChangesAsync();
                _currentUser = user;
                await SaveSession(user.Id);
                await LoadGuests();
                await LoadFaqItems();
            }
            else
            {
                // Verify password
                if (BCrypt.Net.BCrypt.Verify(_password, user.PasswordHash))
