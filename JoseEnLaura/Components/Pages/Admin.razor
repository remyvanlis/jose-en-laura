            await using var db = await DbFactory.CreateDbContextAsync();

            foreach (var text in _siteTexts)
            {
                var dbText = await db.SiteTexts.FindAsync(text.Id);
                if (dbText is not null)
                {
                    dbText.Value = text.Value;
                    dbText.ValueEn = text.ValueEn;
                }
