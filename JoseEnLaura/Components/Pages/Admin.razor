    private async Task LoadSiteImages()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _siteImages = await db.SiteImages
            .Select(i => new SiteImage { Id = i.Id, Name = i.Name, Slot = i.Slot, FileName = i.FileName, ContentType = i.ContentType, Data = Array.Empty<byte>() })
            .ToListAsync();
    }

    private async Task OnImageSelected(string slot, string slotName, InputFileChangeEventArgs e)
    {
        _imageMessage = "";
        _imageError = "";

        var file = e.File;
        if (file is null) return;

        var allowedTypes = new[] { "image/jpeg", "image/png", "image/jpg" };
        if (!allowedTypes.Contains(file.ContentType.ToLower()))
        {
            _imageError = "Alleen JPG, JPEG en PNG bestanden zijn toegestaan.";
            return;
        }

        const long maxSize = 5 * 1024 * 1024; // 5 MB
        if (file.Size > maxSize)
        {
            _imageError = "Bestand is te groot. Maximum is 5 MB.";
            return;
        }

        _isBusy = true;
        StateHasChanged();
        try
        {
            using var stream = file.OpenReadStream(maxSize);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var data = ms.ToArray();

            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.SiteImages.FirstOrDefaultAsync(i => i.Slot == slot);

            if (existing is not null)
            {
                existing.Name = slotName;
                existing.FileName = file.Name;
                existing.ContentType = file.ContentType;
                existing.Data = data;
            }
            else
            {
                db.SiteImages.Add(new SiteImage
                {
                    Name = slotName,
                    Slot = slot,
                    FileName = file.Name,
                    ContentType = file.ContentType,
                    Data = data
                });
            }

            await db.SaveChangesAsync();
            _imageMessage = $"Afbeelding '{file.Name}' geüpload voor {slotName}!";
            await LoadSiteImages();
        }
        catch (Exception ex)
        {
            _imageError = $"Fout bij uploaden: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

