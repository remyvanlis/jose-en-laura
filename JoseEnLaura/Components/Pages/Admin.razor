                    </p>

                    @if (_photoSessions.Count == 0)
                    {
                        <p class="admin-empty">Nog geen foto sessies aangemaakt.</p>
                    }
                    else
                    {
                        var orderedSessions = _photoSessions.OrderBy(s => s.SortOrder).ToList();
